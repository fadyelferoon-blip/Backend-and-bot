# 🔧 MXN Backend - Environment Variables

# Server Port
PORT=5001

# Production Mode
NODE_ENV=production

# ⚠️ مهم جداً: Bot Server URL
# بعد ما ترفع البوت (المشروع 1) على Railway، حط الـ URL هنا
BOT_URL=https://fer3oon-bot-mxn.railway.app

# CORS - Allow all origins
CORS_ORIGIN=*

# ملاحظات:
# 1. استبدل BOT_URL بالـ URL الفعلي من Railway
# 2. في Railway، ضع هذه المتغيرات في Variables tab
# 3. لا تضع هذا الملف في Git
